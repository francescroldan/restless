/* Gateway Project Settings Page Styles */

.gateway-settings-page {
    margin-top: 1px;
    margin-left: 9px;
    flex-shrink: 1;
    flex-grow: 1;
}

.gateway-settings-header {
    -unity-font-style: bold;
    font-size: 19px;
    margin-bottom: 8px;
}

.gateway-settings-scroll {
    flex-grow: 1;
}

.gateway-settings-content {
    margin-top: 6px;
    margin-left: 4px;
    margin-right: 14px;
}

.gateway-settings-row {
    flex-direction: row;
    align-items: center;
    margin-bottom: 8px;
}

.gateway-settings-label {
    width: 150px;
    flex-shrink: 0;
}

.gateway-settings-dropdown {
    flex-grow: 0;
    flex-shrink: 0;
    width: 200px;
}

.gateway-dropdown-with-version {
    flex-direction: row;
    align-items: center;
    flex-grow: 1;
}

.gateway-version-label {
    font-size: 11px;
    margin-left: 8px;
    opacity: 0.5;
}

.gateway-help-row {
    flex-direction: row;
    align-items: center;
    margin-bottom: 12px;
    margin-left: 154px;
    min-height: 20px;
}

.gateway-help-text {
    color: #888888;
    font-size: 11px;
    white-space: normal;
    margin-left: 0;
    margin-bottom: 0;
    -unity-text-align: middle-left;
}

.gateway-add-required-button {
    margin-left: 8px;
    font-size: 11px;
    padding: 2px 8px;
}

.gateway-login-button {
    margin-left: 8px;
    font-size: 11px;
    padding: 2px 8px;
}

/* CLI Path Section */
.gateway-cli-path-container {
    flex-direction: row;
    align-items: center;
}

.gateway-path-row {
    flex-direction: row;
    flex-grow: 1;
    flex-shrink: 1;
    align-items: center;
}

.gateway-cli-path-field {
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 100px;
    margin-right: 8px;
}

.gateway-browse-button {
    width: 80px;
    min-width: 80px;
    flex-shrink: 0;
}

/* Environment Variables Section */
.gateway-env-vars-foldout {
    margin-top: 12px;
    margin-bottom: 8px;
}

.gateway-env-vars-container {
    margin-bottom: 8px;
}

.gateway-env-var-row {
    flex-direction: row;
    align-items: center;
    margin-bottom: 4px;
    flex-wrap: nowrap;
}

.gateway-env-var-lock {
    width: 20px;
    margin-right: 4px;
    -unity-text-align: middle-center;
}

.gateway-env-var-name {
    flex-grow: 0;
    flex-shrink: 0;
    width: 180px;
    min-width: 180px;
    margin-right: 8px;
}

.gateway-env-var-value {
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 100px;
    margin-right: 4px;
}

.gateway-env-var-visibility-button {
    width: 38px;
    height: 24px;
    margin-right: 4px;
}

.gateway-env-var-remove-button {
    width: 24px;
    min-width: 24px;
    height: 24px;
    padding: 0;
    -unity-text-align: middle-center;
    flex-shrink: 0;
    flex-grow: 0;
}

.gateway-env-var-buttons {
    flex-direction: row;
    align-items: center;
    margin-top: 4px;
}

.gateway-add-button {
    align-self: flex-start;
}

.gateway-reset-button {
    margin-left: 8px;
}

.gateway-settings-content .error-message {
    color: #c03333;
    -unity-font-style: bold;
}

/* Disclaimer Section */
.gateway-disclaimer-box {
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    padding: 12px;
    margin-top: 12px;
    margin-left: 4px;
    margin-right: 14px;
    margin-bottom: 14px;
}

.gateway-disclaimer-heading-row {
    flex-direction: row;
    align-items: flex-start;
}

.gateway-disclaimer-info-icon {
    width: 16px;
    height: 16px;
    margin-right: 6px;
    flex-shrink: 0;
}

.gateway-disclaimer-scroll {
    flex-grow: 1;
    max-width: 560px;
}

.gateway-disclaimer-heading {
    white-space: normal;
    font-size: 14px;
    -unity-font-style: bold;
    margin-bottom: 10px;
}

.gateway-disclaimer-intro {
    white-space: normal;
    font-size: 12px;
    opacity: 0.7;
    margin-bottom: 8px;
}

.gateway-disclaimer-bullet {
    white-space: normal;
    font-size: 12px;
    opacity: 0.7;
    margin-top: 8px;
    padding-left: 4px;
}

.gateway-disclaimer-footer {
    white-space: normal;
    font-size: 12px;
    opacity: 0.7;
    -unity-font-style: italic;
    margin-top: 16px;
}

.gateway-disclaimer-button-row {
    flex-direction: row;
    justify-content: flex-end;
    max-width: 560px;
    margin-top: 12px;
}

.gateway-disclaimer-accept-button {
    height: 28px;
    min-width: 80px;
}

.gateway-disclaimer-signin-label {
    display: none;
    white-space: normal;
    font-size: 12px;
    opacity: 0.7;
    -unity-text-align: middle-center;
    max-width: 560px;
    height: 28px;
    margin-top: 12px;
}

/* Per-Provider Sections */
.gateway-provider-section {
    margin-bottom: 12px;
}

.gateway-provider-header-row {
    flex-direction: row;
    align-items: center;
    margin-bottom: 8px;
}

.gateway-provider-header {
    -unity-font-style: bold;
    font-size: 14px;
}

.gateway-enable-agent-row {
    flex-direction: row;
    align-items: center;
    margin-bottom: 4px;
}

.gateway-enable-agent-toggle {
    margin-left: 0;
    padding-left: 0;
}

.gateway-enable-agent-toggle > .unity-label {
    width: 150px;
    min-width: 150px;
}

.gateway-enable-agent-hint {
    font-size: 11px;
    opacity: 0.5;
    margin-left: 8px;
}